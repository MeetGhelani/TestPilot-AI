{
  "name": "ai-test-tool",
  "version": "1.0.0",
  "description": "AI-powered functional testing tool for web, mobile, and desktop apps",
  "scripts": {
    "server": "ts-node server/index.ts",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "tsc"
  },
  "dependencies": {
    "appium": "^3.2.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "ora": "^8.0.1",
    "playwright": "^1.44.0",
    "webdriverio": "^9.26.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "ts-node": {
    "transpileOnly": true,
    "esm": false
  }
}
