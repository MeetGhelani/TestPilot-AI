{
  "name": "ai-test-tool",
  "version": "1.0.0",
  "description": "AI-powered functional testing tool for web, mobile, and desktop apps",
  "scripts": {
    "server": "ts-node server/index.ts",
    "client": "npm run dev --prefix client",
    "dev": "concurrently --kill-others -n \"CLIENT,SERVER\" -c \"cyan,magenta\" \"npm run client\" \"npm run server\"",
    "build": "tsc",
    "install-client": "npm install --prefix client --legacy-peer-deps",
    "install-server": "npm install --prefix server --legacy-peer-deps",
    "install-all": "npm install --legacy-peer-deps && npm run install-client && npm run install-server && npx playwright install chromium",
    "setup": "npm run install-all && npm run dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "appium": "^1.22.3",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "ora": "^8.0.1",
    "playwright": "^1.44.0",
    "webdriverio": "^9.26.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "ts-node": {  
    "transpileOnly": true,
    "esm": false
  }
}
  